# =============================================================================
# IncaCook API — Environment configuration template
# Copy to .env for local development.
# =============================================================================

# -------- App --------
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_NAME=incacook-api
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# -------- Database (Supabase Postgres) --------
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres

# -------- Supabase --------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# -------- Storage --------
SUPABASE_STORAGE_BUCKET_LISTINGS=listings
SUPABASE_STORAGE_BUCKET_KYC=kyc
SUPABASE_STORAGE_BUCKET_AVATARS=avatars

# -------- Redis --------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -------- RevenueCat (seller monthly subscription — App Store / Google Play) --------
# Used ONLY for the seller subscription. Stripe stays for payouts/wallet/orders.
# REVENUECAT_SECRET_API_KEY (sk_…): optional. When set, POST /v1/sellers/me/
#   subscription/sync verifies the subscriber against RevenueCat's REST API
#   instead of trusting the client.
# REVENUECAT_WEBHOOK_AUTH_TOKEN: the exact value set in RevenueCat dashboard →
#   Project → Webhooks → Authorization header. POST /v1/webhooks/revenuecat
#   rejects any request whose Authorization header doesn't match it.
REVENUECAT_SECRET_API_KEY=test_TcJwhvAUrAZXfzwSbaWFyoZguIK

REVENUECAT_WEBHOOK_AUTH_TOKEN=

# -------- Stripe --------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx
# Connect Express onboarding redirect targets (HTTPS). Point at the Flutter
# app's universal-link host or a deep-link bridge. Required when the
# /v1/stripe/onboarding/account-link endpoint is used.
STRIPE_ONBOARDING_RETURN_URL=
STRIPE_ONBOARDING_REFRESH_URL=

# -------- Google OAuth (Web client used as ID-token audience) --------
# Read by the Supabase auth container — see supabase/config.toml
# [auth.external.google]. Required for POST /v1/auth/google to work.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# -------- Twilio --------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -------- Firebase (FCM) --------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# -------- Mapbox --------
MAPBOX_ACCESS_TOKEN=

# -------- Email (Resend) --------
RESEND_API_KEY=
EMAIL_FROM=noreply@incacook.com

# -------- Email senders: who sends what (IMPORTANT) --------
# There are TWO independent email senders in this project:
#
#   1. Backend-managed emails (order receipts, notifications, etc.) — sent by
#      the NestJS mailer using RESEND_API_KEY / MAIL_* (nodemailer/Gmail SMTP).
#
#   2. Supabase Auth emails — signup confirm, password recovery, and the
#      EMAIL OTP used by POST /v1/auth/email/request-otp (the Facebook
#      "complete email" flow + the phone-verification email bypass). These are
#      sent by SUPABASE, NOT by the backend MAIL_* vars. Setting MAIL_* alone
#      will NOT change who sends the OTP email or what it contains.
#
# --- Supabase Auth OTP checklist (do this in the Supabase Dashboard) ---
# a) Custom SMTP (so OTP mail isn't rate-limited by Supabase's shared sender):
#      Authentication → Settings → SMTP Settings → enable + fill host/port/
#      user/pass/from. (You can reuse the Gmail SMTP creds here, but they live
#      in the Supabase Dashboard, not in this backend .env.)
# b) The OTP must be a 6-DIGIT CODE, not a sign-in link. The code from
#    `signInWithOtp` is rendered by the **Magic Link** template, so:
#      Authentication → Email Templates → Magic Link → the body MUST include
#      `{{ .Token }}` (the 6-digit code), e.g.:
#
#        <h2>Votre code de vérification IncaCook</h2>
#        <p>Voici votre code :</p>
#        <h1 style="font-size:32px;letter-spacing:6px;">{{ .Token }}</h1>
#        <p>Ce code expire bientôt. Ne le partagez avec personne.</p>
#
#    If the template only contains `{{ .ConfirmationURL }}` the user receives a
#    LINK instead of a code and the in-app CompleteEmailScreen cannot continue.
#    (The "Reset Password" template already uses `{{ .Token }}` — mirror it.)
#
# SECURITY: never commit a real SMTP/app password to git. If a Gmail App
# Password is ever exposed, REVOKE + rotate it at
# https://myaccount.google.com/apppasswords and replace it everywhere it's set.

# -------- Sentry --------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# -------- JWT (backend-issued) --------
JWT_SECRET=replace_me_with_long_random_string
JWT_EXPIRATION=7d

# -------- Rate limiting --------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# -------- Business rules --------
COMMISSION_PERCENTAGE_STANDARD=30
COMMISSION_PERCENTAGE_PREMIUM=25
COMMISSION_MINIMUM_EUROS=1
DELIVERY_FEE_EUROS=2.50
WITHDRAWAL_MINIMUM_EUROS=50
LE_BON_FAIT_MAISON_PRICE_CAP=4.50
