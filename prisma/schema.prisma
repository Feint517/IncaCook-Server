// =============================================================================
// IncaCook — v1 Prisma schema (thin first slice)
//
// Conventions
// - Primary keys are ULIDs generated at the application layer (`ulid()`).
//   Stored as String (Postgres `text`).
// - Money is stored as integer cents (EUR only in v1).
// - Commission rate is stored in basis points (3000 = 30.00%).
// - Soft delete via `deletedAt DateTime?` on user-editable entities. Financial
//   rows (Order, OrderItem, Delivery, AuditLog, IdempotencyKey) are
//   hard-delete-forbidden by policy.
// - Geo columns use PostGIS `geography(Point, 4326)`. Prisma cannot type or
//   query these natively; reads/writes go through raw SQL or a Prisma
//   extension. GIST indexes must be added via a hand-edited migration step.
// - Postgres enums are mirrored from src/common/enums/*.ts. Adding a value
//   requires a migration — by design, so code can't produce a state the DB
//   doesn't accept.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis]
}

// -------- Enums --------

enum UserRole {
  BUYER
  SELLER
  DRIVER
  ADMIN
  MODERATOR
}

enum SellerCategory {
  FAIT_MAISON
  TRAITEUR
  RESTAURANT
}

enum DietaryTag {
  HALAL
  VEGAN
  GLUTEN_FREE
  CASHER
}

enum Allergen {
  // EU-mandated 14-item allergen list. French names.
  GLUTEN
  CRUSTACES
  OEUFS
  POISSONS
  ARACHIDES
  SOJA
  LAIT
  FRUITS_A_COQUE
  CELERI
  MOUTARDE
  SESAME
  SULFITES
  LUPIN
  MOLLUSQUES
}

enum SavedAddressType {
  HOME
  WORK
  OTHER
}

enum KycStatus {
  // PENDING is the post-signup default for traiteur/restaurant sellers and
  // for drivers. fait_maison sellers are auto-promoted to APPROVED via an
  // INSERT trigger on SellerProfile (no admin review required).
  PENDING
  APPROVED
  REJECTED
}

enum CuisineType {
  // Doc lists this as a "lookup table (will grow)" candidate; we start with
  // a Postgres enum and migrate values in as they're added.
  ORIENTALE
  FRANCAISE
  AFRICAINE
  PORTUGAISE
  ITALIENNE
  ESPAGNOLE
  LATINE
}

enum DishType {
  ENTREE
  PLAT
  DESSERT
  COCKTAIL_DINATOIRE
  BOISSON
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum IdDocumentType {
  CARTE_IDENTITE
  PASSEPORT
  TITRE_SEJOUR
}

// Disambiguates an Address row by role context. Buyer can have several rows
// of kind BUYER_DELIVERY (saved delivery addresses); seller and driver have
// at most one (SELLER_PICKUP / DRIVER_HOME) — enforced by partial unique idx
// added in the migration.
enum AddressKind {
  BUYER_DELIVERY
  SELLER_PICKUP
  DRIVER_HOME
}

// Which "slot" a KycDocument fills. Orthogonal to IdDocumentType (carte
// d'identite vs passeport) — that lives in the row's metadata.
enum KycDocType {
  ID_FRONT
  ID_BACK
  SELFIE
  DRIVING_LICENSE
  CARTE_GRISE
  INSURANCE
}

// Versioned legal/charter documents. CGU/CGV are also modeled here so the
// app can re-prompt on version bumps without an app release. The two
// booleans on User remain as a fast "did this user accept any version yet"
// flag, but the source of truth for which version is in UserCharter.
enum CharterKind {
  CGU
  CGV
  HYGIENE
  FAIT_MAISON
  PUNCTUALITY
  CARE
}

enum Fulfillment {
  DELIVERY
  PICKUP
  BOTH
}

enum DriverVehicleType {
  BICYCLE
  SCOOTER
  CAR
}

enum RatingCriterion {
  HYGIENE
  FOOD_QUALITY
  PACKAGING
}

enum FulfillmentChoice {
  DELIVERY
  PICKUP
}

enum DeliveryTiming {
  ASAP
  SCHEDULED
}

enum IssueSeverity {
  ABORT // driver cannot continue — order needs admin intervention
  REPORT // mid-job concern; delivery proceeds
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  PICKED_UP
  IN_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum DeliveryStatus {
  UNASSIGNED
  SEARCHING
  ASSIGNED
  EN_ROUTE_TO_PICKUP
  AT_PICKUP
  PICKED_UP
  EN_ROUTE_TO_DROPOFF
  AT_DROPOFF
  DELIVERED
  CANCELLED
  FAILED
}

// -------- Identity --------

model User {
  id         String   @id
  // Foreign key to Supabase Auth `auth.users.id`. The Supabase JWT carries
  // this in the `sub` claim. Source of truth for credentials lives in
  // Supabase; this row holds IncaCook-domain profile fields.
  supabaseId String   @unique
  email      String   @unique
  phone      String?  @unique
  role       UserRole @default(BUYER)

  firstName  String
  lastName   String
  avatarPath String?

  // Mirrored from Supabase auth so we can filter without touching the auth
  // schema. Kept in sync via the auth webhook / on-login refresh.
  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)

  // Legal terms acceptance captured at signup. acceptedAt is set when both
  // CGU and CGV are accepted; required to satisfy GDPR/consumer-law records.
  acceptedCgu Boolean   @default(false)
  acceptedCgv Boolean   @default(false)
  acceptedAt  DateTime?

  // Populated as a side effect of the buyer's first payment — not at signup.
  stripeCustomerId String? @unique

  // GDPR: erasure is performed by anonymising this row, not deleting.
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sellerProfile SellerProfile?
  driverProfile DriverProfile?
  buyerProfile  BuyerProfile?
  addresses     Address[]

  buyerOrders     Order[]          @relation("BuyerOrders")
  catalogOrders   CatalogOrder[]   @relation("SellerCatalogOrders")
  auditLogs       AuditLog[]
  idempotencyKeys IdempotencyKey[]

  kycDocuments       KycDocument[] @relation("KycAuthor")
  kycReviewsAuthored KycDocument[] @relation("KycReviewer")

  charters UserCharter[]

  reviewsAuthored Review[]   @relation("ReviewAuthor")
  bookmarks       Bookmark[]

  // Chat — see Conversation / ConversationParticipant / Message.
  chatParticipations ConversationParticipant[] @relation("ConversationParticipantUser")
  chatMessages       Message[]                 @relation("MessageSender")

  // FCM push-notification registration tokens (one row per device token).
  deviceTokens DeviceToken[]

  @@index([role])
  @@index([deletedAt])
}

/// An FCM registration token for one of a user's devices. `token` is unique,
/// so re-registering an existing token re-points it at the current user and
/// refreshes `updatedAt` instead of creating a duplicate
/// (see DeviceTokensService.register). `platform` holds 'ANDROID' | 'IOS' |
/// 'WEB', validated at the DTO layer (RegisterDeviceTokenDto).
model DeviceToken {
  id       String @id
  token    String @unique
  platform String
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// Seller platform-subscription state, mirrored from Stripe by the
/// subscription webhooks. NONE = never subscribed. Seller features are
/// gated on ACTIVE/TRIALING (with a valid current-period-end).
enum SubscriptionStatus {
  NONE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  // Subscription lapsed (RevenueCat EXPIRATION event / past current period).
  EXPIRED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

model SellerProfile {
  // Stub row created at Gate 2 (POST /v1/users with role=SELLER). All
  // signup fields are nullable: the wizard fills them in via per-concept
  // PUT endpoints (Phase B). Listing-creation gates check `canList()` (all
  // required fields present + kycStatus APPROVED) before allowing publish.
  userId String @id
  user   User   @relation(fields: [userId], references: [id])

  category    SellerCategory?
  displayName String?
  bio         String?

  // Storage object key in `avatars/`. Resolved to a signed URL at read time.
  profilePhotoUrl String?

  dateOfBirth DateTime? @db.Date

  // Pickup address now lives in Address with kind=SELLER_PICKUP. Read by
  // querying Address WHERE userId=X AND kind='SELLER_PICKUP' (partial
  // unique idx guarantees at most one row).

  // Business info — businessName / siret / facadeUrl / openingHours all
  // moved to SellerBusiness. Fait-maison sellers don't have a business row;
  // service code derives "skipped" from absence + category.
  business SellerBusiness?

  // Cuisine + dish selections moved out of array columns into join tables
  // for indexed lookups in the buyer feed.
  cuisines SellerCuisine[]
  dishes   SellerDish[]

  hygieneCommitment    Boolean? // null = not yet accepted
  faitMaisonCommitment Boolean?

  // Service area + economics. Filled via PUT /v1/sellers/me/profile.
  deliveryRadiusKm Decimal? @db.Decimal(4, 1)
  deliveryFeeCents Int?

  // Prep window (minutes). prepMaxMinutes >= prepMinMinutes (service-layer).
  prepMinMinutes Int?
  prepMaxMinutes Int?

  neighborhood  String?
  languageCodes String[] @default([]) // ISO codes

  // Free-text human-readable schedule. Structured opening hours live in
  // SellerOpeningHours under SellerBusiness (non-fait-maison only).
  availabilitySchedule String?

  // Internal badge keys ("verified", "top-seller", etc.).
  verifications String[] @default([])

  promoText   String?
  categoryTag String?

  // Denormalized from the pickup Address.point for radius queries on the
  // listing feed. Written via raw SQL when the seller PUTs their pickup
  // address. GIST-indexed in the migration.
  location Unsupported("geography(Point, 4326)")?

  // INSERT trigger sets this to APPROVED for FAIT_MAISON (no admin review).
  // Application code also computes the right value on insert; the trigger
  // is a safety net.
  kycStatus KycStatus @default(PENDING)

  // Stripe Express Connect account for receiving payouts. Created via
  // Stripe Connect onboarding. Onboarding completion is flipped by the
  // `account.updated` webhook when charges_enabled, payouts_enabled, and
  // details_submitted are all true.
  stripeConnectAccountId    String? @unique
  stripeOnboardingCompleted Boolean @default(false)

  isPremium     Boolean @default(false) // 25% commission tier vs 30%
  totalOrders   Int     @default(0)
  averageRating Float?
  reviewCount   Int     @default(0)

  // Mandatory monthly platform subscription ($4/mo). The seller cannot use
  // seller features (list/edit/publish products, receive orders, appear in
  // the feed) until this is active. Stripe is the source of truth — these
  // columns are written by the subscription webhooks. The Stripe customer
  // is the same one stored on User.stripeCustomerId.
  stripeSubscriptionId         String?            @unique
  subscriptionStatus           SubscriptionStatus @default(NONE)
  // End of the current paid period ("subscriptionExpiresAt"). Active when
  // status ∈ {ACTIVE, TRIALING} AND this is in the future.
  subscriptionCurrentPeriodEnd DateTime?

  // RevenueCat seller subscription (App Store / Google Play). The seller's
  // monthly platform plan now runs through RevenueCat instead of Stripe
  // Billing; these mirror the SAME `subscriptionStatus` /
  // `subscriptionCurrentPeriodEnd` / `isPremium` gate fields above, so the
  // listing-creation gate (isSubscriptionActive) and the commission tier
  // (isPremium) need no change. Written optimistically by
  // POST /v1/sellers/me/subscription/sync and reconciled authoritatively by
  // the RevenueCat webhook. Stripe stays the source of truth for payouts,
  // wallet and order payments — never for this subscription.
  revenueCatCustomerId  String? // RevenueCat app_user_id (= our User.id)
  revenueCatEntitlement String? // "seller_standard" | "seller_premium"
  subscriptionPlan      String? // "STANDARD" | "PREMIUM"
  subscriptionProductId String? // store product identifier
  subscriptionCategory  SellerCategory? // category the plan was bought for
  trialEndsAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings Listing[]
  orders   Order[]   @relation("SellerOrders")
  reviews  Review[]  @relation("SellerReviews")

  @@index([category])
  @@index([kycStatus])
}

model DriverProfile {
  // Stub row created at Gate 2 (POST /v1/users with role=DRIVER). All
  // signup fields are nullable: the wizard fills them in via per-concept
  // PUT endpoints (Phase B). Delivery-assignment gates check `canDeliver()`
  // (required fields + KYC APPROVED + Stripe onboarded) before matching.
  userId String @id
  user   User   @relation(fields: [userId], references: [id])

  dateOfBirth DateTime? @db.Date

  // Base address now lives in Address with kind=DRIVER_HOME. Read by
  // querying Address WHERE userId=X AND kind='DRIVER_HOME' (partial unique
  // idx guarantees at most one row).

  vehicleType DriverVehicleType?

  // Driver zones moved out of array column into a join table — same
  // motivation as SellerCuisine.
  zones DriverZone[]

  charterAccepted       Boolean? // null = not yet accepted
  punctualityCommitment Boolean?
  careCommitment        Boolean?

  kycStatus KycStatus @default(PENDING)

  // Stripe Express Connect account for receiving payouts. Same lifecycle as
  // SellerProfile — flipped to onboarded by the `account.updated` webhook.
  stripeConnectAccountId    String? @unique
  stripeOnboardingCompleted Boolean @default(false)

  // Real-time location is broadcast through Redis; this column is a periodic
  // flush of the last known position for offline reads and history.
  lastKnownPoint Unsupported("geography(Point, 4326)")?
  lastSeenAt     DateTime?
  isOnline       Boolean                                @default(false)

  averageRating   Float?
  totalDeliveries Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries  Delivery[]
  orderIssues OrderIssue[] @relation("DriverOrderIssues")

  @@index([isOnline])
  @@index([kycStatus])
}

model BuyerProfile {
  // Default delivery address moved to Address with kind=BUYER_DELIVERY.
  // Multiple rows per user allowed (HOME / WORK / OTHER via Address.type);
  // app-level convention: the most-recently-updated row is "default".
  userId String @id
  user   User   @relation(fields: [userId], references: [id])

  // Postgres enum arrays. Default to empty rather than NULL so reads never
  // need a null-check.
  dietaryPreferences DietaryTag[] @default([])
  allergies          Allergen[]   @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id     String @id
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Role-context kind. Replaces the old per-role FKs on profile tables.
  // Buyer can have several BUYER_DELIVERY rows; seller and driver each
  // have at most one (SELLER_PICKUP / DRIVER_HOME) — enforced by partial
  // unique idx added in the migration.
  kind AddressKind

  type        SavedAddressType?
  customLabel String?

  fullAddress String
  city        String
  // Nullable: some places (town-level / non-FR results) carry no postcode.
  postalCode  String?

  // PostGIS geography(Point, 4326). Written via raw SQL (`ST_MakePoint`).
  // GIST index added in the migration for radius queries.
  point Unsupported("geography(Point, 4326)")?

  apartment     String?
  floor         String?
  digicode      String?
  deliveryNotes String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ordersWithDropoff Order[] @relation("OrderDropoff")

  @@index([userId])
  @@index([userId, kind])
  @@index([deletedAt])
}

model SellerBusiness {
  // 1:1 with SellerProfile, but only present for non-fait-maison sellers.
  // Holds the legally-required business identity (SIRET, business name,
  // facade) plus the weekly opening hours.
  userId String        @id
  seller SellerProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  businessName String
  // 14-digit, Luhn-validated. Unique across the platform.
  siret        String  @unique
  // Storage key in `seller-facades/`. Resolved to a signed URL at read time.
  facadeUrl    String?
  legalForm    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  openingHours SellerOpeningHours[]
}

model SellerCuisine {
  // Indexed join — buyer feed filters by cuisine, so an exact-match index
  // beats Postgres array containment for selectivity.
  userId      String
  cuisineType CuisineType
  seller      SellerProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([userId, cuisineType])
  @@index([cuisineType])
}

model SellerDish {
  userId   String
  dishType DishType
  seller   SellerProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([userId, dishType])
  @@index([dishType])
}

model DriverZone {
  // Free-text zone identifiers ("Bastille", "Marais", etc.). Future v2 will
  // promote these to a `Zone` lookup with a polygon geography column.
  userId String
  zoneId String
  driver DriverProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([userId, zoneId])
  @@index([zoneId])
}

model UserCharter {
  // Versioned acceptance record. Each new version a user accepts is a new
  // row — keeps the audit trail of which version was current when they
  // agreed. PK on (userId, charter, version) so re-prompting on a version
  // bump appends rather than overwrites.
  userId     String
  charter    CharterKind
  version    String
  acceptedAt DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, charter, version])
  @@index([userId, charter, acceptedAt(sort: Desc)])
}

model LegalDocument {
  // Admin-editable CGU/CGV documents. The active row per kind is the canonical
  // published text the mobile app shows and that publish/purchase acceptance is
  // recorded against (see record-terms-acceptance.util.ts). Drafts
  // (isActive=false) are editable; publishing flips exactly one active row per
  // kind and notifies users. Reuses CharterKind (only CGU/CGV are managed here)
  // so acceptance keeps flowing through the existing UserCharter ledger.
  id          String      @id
  kind        CharterKind
  version     String
  title       String
  content     String
  isActive    Boolean     @default(false)
  publishedAt DateTime?
  // Audit: local User.id of the admin who created / last edited the row.
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([kind, version])
  @@index([kind, isActive])
}

model KycDocument {
  // One row per uploaded document. Unique on (userId, type): a new upload
  // for the same slot supersedes the previous (older fileUrl is overwritten
  // — we don't keep KYC history beyond what storage retains).
  id              String     @id
  userId          String
  user            User       @relation("KycAuthor", fields: [userId], references: [id], onDelete: Cascade)
  type            KycDocType
  // Storage key in `kyc/`. Resolved to a signed URL at read time.
  fileUrl         String
  reviewState     KycStatus  @default(PENDING)
  reviewerId      String?
  reviewer        User?      @relation("KycReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  rejectionReason String?
  // Stashes per-slot metadata that doesn't warrant a column. Today: the
  // IdDocumentType (CARTE_IDENTITE / PASSEPORT / TITRE_SEJOUR) on ID_FRONT
  // / ID_BACK rows so admins know what they're reviewing.
  metadata        Json?
  submittedAt     DateTime   @default(now())

  @@unique([userId, type])
  @@index([reviewState, submittedAt])
  @@index([userId])
}

model SellerOpeningHours {
  // 1:N with SellerBusiness — only sellers that have a business row (i.e.
  // non-fait-maison) have opening hours. Fait-maison sellers operate on
  // their listings' explicit pickup windows.
  sellerId String
  seller   SellerBusiness @relation(fields: [sellerId], references: [userId], onDelete: Cascade)

  dayOfWeek DayOfWeek
  // Local time, no zone — the seller's local opening time.
  startTime DateTime  @db.Time()
  endTime   DateTime  @db.Time()

  @@id([sellerId, dayOfWeek])
}

// -------- Catalog --------

model Listing {
  id       String        @id
  sellerId String
  seller   SellerProfile @relation(fields: [sellerId], references: [userId])

  name        String
  description String?
  // Up to 3 image URLs (storage object keys in `listings/`). DB CHECK
  // constraint enforces the cap.
  imageUrls   String[] @default([])

  // Money in cents (project-wide convention).
  priceCents         Int
  originalPriceCents Int? // pre-discount, when on promo
  discountPercent    Int? // 0–100; could be derived but stored for query perf

  // null = "cook to order" (restaurant/traiteur). Required for fait_maison —
  // enforced at the API layer (docs/posting-module.md §3.3).
  portionsLeft Int?

  // Each listing carries 0+ cuisines and 0+ dish types (multi-select form).
  // See docs/posting-module.md §2.6.d.
  cuisineTypes   CuisineType[] @default([])
  dishTypes      DishType[]    @default([])
  dietaryTags    DietaryTag[] @default([])
  allergens      Allergen[]   @default([])
  // Free-text long-tail allergens (the 14-item enum doesn't cover everything).
  otherAllergens String?

  isAvailable Boolean @default(true)
  isVeg       Boolean @default(false)

  // Free-text seller-defined sub-category like "Pizza mixte".
  menuCategory String?

  // Denormalized from SellerProfile.category at insert time. Avoids a join
  // when filtering the buyer feed by seller category. Server-set, not from
  // request body.
  category SellerCategory

  // delivery | pickup | both — how this dish can be fulfilled.
  fulfillment Fulfillment

  // Per-dish prep time in minutes. Distinct from SellerProfile's
  // prepMin/Max which describe the kitchen's overall range.
  prepMinutes Int

  // Auto-hide from the buyer feed at this point. null = permanent menu item
  // (restaurant/traiteur). Required for fait_maison — enforced at the API
  // layer (docs/posting-module.md §3.3).
  expiresAt DateTime?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  orderItems OrderItem[]
  addOns     ListingAddOn[]
  bookmarks  Bookmark[]

  @@index([sellerId, isAvailable, expiresAt])
  @@index([isAvailable, expiresAt])
  @@index([category, isAvailable, expiresAt])
  @@index([deletedAt])
  @@index([cuisineTypes], type: Gin)
  @@index([dishTypes], type: Gin)
}

model ListingAddOn {
  id        String  @id
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  label               String
  // Can be negative (e.g. "no cheese: -0.50€").
  priceDeltaCents     Int
  isSelectedByDefault Boolean @default(false)
  // Server-managed; sellers don't set this directly. Used to preserve order
  // across PATCH replacements.
  sortOrder           Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId, sortOrder])
}

model Bookmark {
  // Buyer's saved listing. Composite PK so duplicate POSTs are no-ops.
  // Cascades on listing deletion (no point keeping a bookmark to a gone
  // listing). User deletion stays restricted — User.deletedAt soft-deletes
  // and we want to retain the bookmark history if the user is restored.
  buyerId   String
  buyer     User    @relation(fields: [buyerId], references: [id])
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([buyerId, listingId])
  @@index([buyerId, createdAt(sort: Desc)])
  // Used by SellerStats.mealsSaved (count via listing.sellerId).
  @@index([listingId])
}

// -------- Commerce --------

model Order {
  id          String @id
  // Human-friendly short code (e.g. "X3K7M9") for support and notifications.
  orderNumber String @unique

  buyerId String
  buyer   User   @relation("BuyerOrders", fields: [buyerId], references: [id])

  sellerId String
  seller   SellerProfile @relation("SellerOrders", fields: [sellerId], references: [userId])

  status OrderStatus @default(PENDING)

  // Pricing snapshot — frozen at creation. Listing/commission changes after
  // this point do not affect the order.
  subtotalCents       Int
  fulfillmentFeeCents Int // 0 for pickup, seller's deliveryFeeCents for delivery
  commissionRateBps   Int // basis points: 3000 = 30.00%
  commissionCents     Int
  sellerEarningsCents Int // subtotalCents - commissionCents
  buyerTotalCents     Int // subtotalCents + fulfillmentFeeCents

  // Buyer's choice at checkout (subset of seller's offered Fulfillment).
  fulfillmentChoice FulfillmentChoice

  // Drop-off — full Address row (so we get postal_code, lat/lng, etc.).
  // Null for PICKUP orders: the buyer collects from the seller, so there
  // is no delivery address.
  dropoffAddressId     String?
  dropoffAddress       Address? @relation("OrderDropoff", fields: [dropoffAddressId], references: [id])
  deliveryInstructions String?

  // Scheduling.
  deliveryTiming DeliveryTiming @default(ASAP)
  scheduledAt    DateTime? // when the buyer wants the food ready / delivered
  expectedAt     DateTime? // server-computed ETA (placedAt + prep + delivery)

  // Free-text note from the buyer ("ring twice", "no nuts please", …).
  note String?

  // Stripe PaymentIntent for this order. Set after the PI is created.
  // Backfilled by the webhook handler if the post-create update fails.
  stripePaymentIntentId String? @unique

  // Idempotency flag for the inventory restoration on payment_failed /
  // canceled webhooks AND seller cancellations — all paths can fire
  // multiple times.
  inventoryRestored Boolean @default(false)

  // Set when a Stripe refund has been initiated for this order (seller
  // cancel today; admin/buyer refunds in future slices). Guards against
  // double-refunding on retried calls.
  stripeRefundId String?   @unique
  refundedAt     DateTime?

  // Set when funds are released to the seller after delivery completes
  // (separate-charges → manual transfer pattern). Guards against
  // double-paying on retried calls.
  stripeTransferId       String?   @unique
  // Driver's payout (the fulfillment fee). Null for PICKUP orders.
  stripeDriverTransferId String?   @unique
  transferredAt          DateTime?

  // Lifecycle timestamps. status is the source of truth; these mirror it for
  // analytics and SLA reporting.
  placedAt           DateTime  @default(now())
  confirmedAt        DateTime?
  readyAt            DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         OrderItem[]
  deliveries    Delivery[]
  review        Review?
  conversations Conversation[] @relation("ConversationOrder")

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([sellerId, createdAt(sort: Desc)])
  @@index([status, createdAt])
}

model Review {
  id String @id

  // One review per order (UNIQUE FK). Cascades nothing — financial rows
  // are hard-delete-forbidden by policy, so the order will never disappear
  // out from under the review.
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  authorId String
  author   User   @relation("ReviewAuthor", fields: [authorId], references: [id])

  // FK to SellerProfile.userId (the seller's user_id PK).
  sellerId String
  seller   SellerProfile @relation("SellerReviews", fields: [sellerId], references: [userId])

  // Overall 1–5 stars. Doc references `reviews.rating` even though the
  // table schema doesn't list it — adding here for per-review display
  // and for the cached SellerProfile.averageRating denormalization.
  rating Int

  body         String
  helpfulCount Int    @default(0)

  createdAt DateTime @default(now())

  criteriaRatings ReviewCriterionRating[]

  @@index([sellerId, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
}

model ReviewCriterionRating {
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  criterion RatingCriterion

  // numeric(4,1) accommodates both score5 (0–5 with one decimal) and
  // percent (0–100). value_type is fixed by criterion at the application
  // boundary — not stored.
  value       Decimal @db.Decimal(4, 1)
  // Number of underlying observations for this criterion. Defaults to 1
  // for a per-review rating; reserved for potential weighted aggregations.
  sampleCount Int     @default(1)

  @@id([reviewId, criterion])
}

model OrderItem {
  id      String @id
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])

  // Listing snapshots — frozen at order creation so historical orders stay
  // readable after listing edits/deletes. Names match BACKEND_SCHEMA.md.
  listingNameSnapshot     String
  listingImageUrlSnapshot String?
  unitPriceCentsSnapshot  Int

  quantity Int
  // Free-text per-item note from the buyer ("no onions").
  note     String?

  createdAt DateTime @default(now())

  addOns OrderItemAddOn[]

  @@index([orderId])
  @@index([listingId])
}

model OrderItemAddOn {
  // Snapshot of a ListingAddOn at order time. Lives on its own row (not
  // a JSON column) so we can sum/aggregate addons in reports if needed.
  id          String    @id
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  labelSnapshot           String
  priceDeltaCentsSnapshot Int

  createdAt DateTime @default(now())

  @@index([orderItemId])
}

// -------- Fulfillment --------

model Delivery {
  id      String @id
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  // Null while in SEARCHING/UNASSIGNED. A failed delivery may be reassigned
  // by inserting a new Delivery row pointing at the same Order.
  driverId String?
  driver   DriverProfile? @relation(fields: [driverId], references: [userId])

  status DeliveryStatus @default(UNASSIGNED)

  pickupEta  DateTime?
  dropoffEta DateTime?

  driverAssignedAt DateTime?
  pickedUpAt       DateTime?
  deliveredAt      DateTime?
  failedAt         DateTime?
  failureReason    String?

  proofOfDeliveryPath String? // Supabase Storage path

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issues OrderIssue[]

  @@index([orderId])
  @@index([driverId, status])
  @@index([status])
}

model OrderIssue {
  // Driver-reported issue mid-delivery. Doc: order_issues.
  id String @id

  // FK to Delivery (not directly to Order) — ties the report to the
  // specific assignment. Order is reachable via delivery.order.
  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  // The driver who filed it. Required.
  driverId String
  driver   DriverProfile @relation("DriverOrderIssues", fields: [driverId], references: [userId])

  // Free-text catalog code from issue_catalog.dart on the Flutter side
  // ("restaurant_closed", "buyer_unreachable", …). Not enumerated here —
  // catalog grows fast and we don't want a migration per code.
  issueCode         String
  severity          IssueSeverity
  // Order status at the moment the issue was reported (for analytics).
  stageWhenReported OrderStatus
  freeText          String?

  reportedAt DateTime @default(now())

  @@index([deliveryId])
  @@index([driverId, reportedAt(sort: Desc)])
  @@index([severity])
}

// -------- Platform plumbing --------

model AuditLog {
  id      String  @id
  // Null for system-initiated actions (cron jobs, webhooks, etc.).
  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])

  action     String // e.g. "order.create", "listing.publish"
  targetType String? // e.g. "Order", "Listing"
  targetId   String?

  metadata      Json?
  correlationId String?
  ipAddress     String?

  createdAt DateTime @default(now())

  @@index([actorId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@index([action, createdAt(sort: Desc)])
}

model IdempotencyKey {
  // Composite uniqueness on (userId, key) — same Idempotency-Key from
  // different users is fine.
  id     String @id
  userId String
  user   User   @relation(fields: [userId], references: [id])

  key            String
  // Hash of method + path + body — lets us detect "same key, different
  // request" and reject as 409.
  requestHash    String
  responseStatus Int
  responseBody   Json

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([userId, key])
  @@index([expiresAt]) // cleanup sweep
}

// ---------------------------------------------------------------------------
// Chat — reusable conversation system shared across buyer↔seller,
// buyer↔delivery, and support threads. Persisted (vs the earlier
// ephemeral Redis-pubsub chat) so history survives app restart and
// unread counts can be tracked per participant.
// ---------------------------------------------------------------------------

enum ConversationType {
  BUYER_SELLER
  BUYER_DELIVERY
  // Seller ↔ assigned driver, created when a delivery is claimed. One thread
  // per order (pinned via Conversation.orderId).
  SELLER_DRIVER
  SUPPORT
}

enum ParticipantRole {
  BUYER
  SELLER
  DELIVERY
  SUPPORT
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

model Conversation {
  id   String           @id
  type ConversationType

  // Optional foreign keys. A BUYER_SELLER conversation may pin to a
  // store; a BUYER_DELIVERY conversation always pins to the order
  // that spawned it (one delivery thread per order, per assignee).
  orderId String?
  order   Order?  @relation("ConversationOrder", fields: [orderId], references: [id])
  storeId String?

  // Denormalized last-message snapshot for list views. Kept in sync
  // by MessagesService on every send.
  lastMessage   String?
  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  // Find-or-create matches against (type, orderId, sorted participants).
  // For BUYER_SELLER without an order, the (type, storeId/null) pair
  // collapses to "one thread per buyer×seller" via service-layer dedup.
  @@index([type, orderId])
  @@index([lastMessageAt(sort: Desc)])
}

model ConversationParticipant {
  id             String       @id
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("ConversationParticipantUser", fields: [userId], references: [id], onDelete: Cascade)

  role ParticipantRole

  // Per-user unread counter (incremented when ANOTHER participant
  // posts; reset to 0 by markRead). Avoids a Set-of-read-message-ids
  // table and is enough for the badge UX.
  unreadCount Int       @default(0)
  lastReadAt  DateTime?

  joinedAt DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId, conversationId])
}

model Message {
  id             String       @id
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  content     String
  messageType MessageType @default(TEXT)

  // Read by the OTHER participant. Optional because group threads
  // (SUPPORT) could have more than two readers; for 1:1 threads this
  // is the moment the counterpart opened the conversation. Currently
  // tracked at the participant level via `lastReadAt`; this field
  // stays nullable for future per-message receipts.
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// Admin product catalog — products created by admins and sold TO sellers.
// Visible only to SELLER role (enforced in the catalog controller). Distinct
// from Listing (a seller's own dishes sold to buyers).
// ---------------------------------------------------------------------------

enum CatalogOrderStatus {
  PENDING // created, awaiting payment
  PAID // seller's card charged
  FAILED // payment failed
  CANCELLED
}

model CatalogProduct {
  id          String   @id
  name        String
  description String?
  imageUrls   String[] @default([])
  priceCents  Int
  currency    String   @default("usd")
  isActive    Boolean  @default(true)

  // Admin (User with role ADMIN/MODERATOR) who created the product.
  // Nullable so admin deletion doesn't cascade-delete catalog rows.
  createdById String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  orderItems CatalogOrderItem[]

  @@index([isActive])
  @@index([deletedAt])
}

model CatalogOrder {
  id       String             @id
  sellerId String
  seller   User               @relation("SellerCatalogOrders", fields: [sellerId], references: [id])
  status   CatalogOrderStatus @default(PENDING)

  totalCents Int
  currency   String @default("usd")

  // Stripe is the source of truth for PAID (confirm-payment + webhook).
  stripePaymentIntentId String? @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  items CatalogOrderItem[]

  @@index([sellerId])
  @@index([status])
}

model CatalogOrderItem {
  id      String       @id
  orderId String
  order   CatalogOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Product reference kept nullable + snapshotted so price/name on the
  // order are stable even if the product is later edited or deleted.
  productId String?
  product   CatalogProduct? @relation(fields: [productId], references: [id])

  nameSnapshot   String
  unitPriceCents Int
  quantity       Int
  lineTotalCents Int

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Moderation — user-submitted reports reviewed by admins. Maps to the
// pre-existing (empty) `Report` table: polymorphic target (targetType +
// targetId) + a `reason` enum (the report TYPE) + free-text `description`.
// NON_FAIT_MAISON / MAUVAISE_HYGIENE were added additively to ReportReason,
// and REJECTED to ReportStatus.
// ---------------------------------------------------------------------------

enum ReportReason {
  // Generic content-moderation reasons (pre-existing).
  SPAM
  INAPPROPRIATE
  OFFENSIVE
  FAKE
  DUPLICATE
  // Client-spec report types:
  //   NON_FAIT_MAISON  — a "Le Bon Fait Maison" dish that isn't home-made
  //                      (only valid for FAIT_MAISON listings — service-enforced).
  //   MAUVAISE_HYGIENE — hygiene concern (any seller category).
  NON_FAIT_MAISON
  MAUVAISE_HYGIENE
  OTHER
}

enum ReportStatus {
  PENDING
  DISMISSED // legacy; unused by the new flow
  RESOLVED
  REJECTED
}

model Report {
  id          String       @id
  reporterId  String
  // Polymorphic target. targetType: 'LISTING' | 'SELLER'; targetId is the
  // Listing.id or seller User.id.
  targetType  String
  targetId    String
  // The report TYPE (exposed as `type` in the API).
  reason      ReportReason
  // Optional free-text comment from the reporter.
  description String?
  status      ReportStatus @default(PENDING)
  // Admin reviewer (User.id) + note, set on resolve/reject.
  reviewedBy  String?
  adminNote   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, createdAt(sort: Desc)])
  // Duplicate-spam guard: same reporter + target + type while PENDING.
  @@index([reporterId, targetId, reason, status])
}

// ---------------------------------------------------------------------------
// Internal wallet ledger. Sellers/drivers are credited here when an order is
// delivered + reception-validated (never on payment). Real Stripe transfers
// to their Connect account happen only on withdrawal (balance >= 50 €).
// ---------------------------------------------------------------------------

enum WalletEntryType {
  ORDER_EARNING // seller net (subtotal - commission)
  DELIVERY_EARNING // driver delivery fee
  COMMISSION // platform cut (recorded under userId='PLATFORM')
  REFUND
  WITHDRAWAL // payout debit
}

enum WalletEntryStatus {
  PENDING
  AVAILABLE
  HELD // disputed / CGU-CGV violation — not payable
  PAID_OUT
  CANCELLED
}

model WalletEntry {
  id           String            @id
  // Beneficiary User.id (seller or driver); 'PLATFORM' for COMMISSION rows.
  userId       String
  orderId      String?
  type         WalletEntryType
  // Positive = credit; negative = debit (WITHDRAWAL).
  amountCents  Int
  currency     String            @default("eur")
  status       WalletEntryStatus @default(AVAILABLE)
  // Groups a payout: the WITHDRAWAL debit + the entries it paid out.
  withdrawalId String?
  availableAt  DateTime?
  metadata     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Idempotency: one earning/commission row per (order, user, type). Payout
  // rows have orderId=null (Postgres treats NULLs as distinct → many allowed).
  @@unique([orderId, userId, type])
  @@index([userId, status])
  @@index([orderId])
}
